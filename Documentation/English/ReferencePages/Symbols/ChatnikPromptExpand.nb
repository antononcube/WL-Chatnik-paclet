Cell[TextData[{
 "Expand a prompt that refers to an LLM persona (\"",
 ButtonBox["SouthernBelleSpeak",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://resources.wolframcloud.com/PromptRepository/resources/\
SouthernBelleSpeak"], None},
  ButtonNote->
   "https://resources.wolframcloud.com/PromptRepository/resources/\
SouthernBelleSpeak"],
 "\"):"
}], "ExampleText",
 CellChangeTimes->{{3.987518158448267*^9, 3.987518217906187*^9}},
 CellID->976993213,ExpressionUUID->"da3059c5-8a71-4517-8ed2-3072dc7aee25"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ChatnikPromptExpand", "[", "\"\<@SouthernBelleSpeak\>\"", 
  "]"}]], "Input",
 CellChangeTimes->{{3.9875047500660563`*^9, 3.987504809584592*^9}, {
  3.987518020326589*^9, 3.987518084617778*^9}, {3.9875181494943933`*^9, 
  3.987518150619907*^9}},
 CellLabel->"In[11]:=",
 CellID->1724838940,ExpressionUUID->"c6535f62-4c5c-4fe4-b440-fce2f1c3ef47"],

Cell[BoxData["\<\"You are Miss Anne. \\nYou speak only using Southern Belle \
terminology and slang.\\nYour personality is elegant and refined.\\nOnly \
return responses as if you were a Southern Belle.\\nNever break the Southern \
Belle character.\\nYou speak with a Southern drawl.\"\>"], "Output",
 CellChangeTimes->{3.987518086998282*^9, 3.987518151840962*^9},
 CellLabel->"Out[11]=",
 CellID->1553928482,ExpressionUUID->"ed3d1994-051b-4f18-b5fe-88413752b358"]
}, Open  ]],

Cell["Expand a prompt with a function that takes arguments:", "ExampleText",
 CellChangeTimes->{{3.987518225259109*^9, 3.987518245555461*^9}},
 CellID->1956164814,ExpressionUUID->"bd9601c4-3068-43fb-a9f7-d8578d37f196"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ChatnikPromptExpand", 
  "[", "\"\<@ThemeTableJSON|'SEE BELOW'|'article'|24\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.9875047500660563`*^9, 3.987504809584592*^9}, {
  3.987518335747714*^9, 3.9875184708881493`*^9}, {3.987518521772393*^9, 
  3.987518627233377*^9}},
 CellLabel->"In[24]:=",
 CellID->384623297,ExpressionUUID->"c1bf6b8e-942a-435e-80a2-4cd5bac226b2"],

Cell[BoxData["\<\"Split the following article into thematic parts:\\n SEE \
BELOW\\n \\n Return the parts as a JSON array. \\n Represent each thematic \
part with a theme-content pair.\\n Make sure each of the content descriptions \
has no more than 24 words.\"\>"], "Output",
 CellChangeTimes->{{3.987518542634557*^9, 3.987518627874155*^9}},
 CellLabel->"Out[24]=",
 CellID->1125990794,ExpressionUUID->"4e87340a-0957-4eb6-898e-2fb57e33e2ef"]
}, Open  ]]
}, Open  ]],

