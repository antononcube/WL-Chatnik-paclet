Notebook[{

Cell[CellGroupData[{
Cell["ChatnikCopyScripts", "ObjectName",
 CellID->507504249,ExpressionUUID->"bf699f8c-89d3-49c7-9075-f05766920494"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"e0f1dbfc-79fa-4785-b23b-349255e58975"],
 Cell[BoxData[
  RowBox[{"ChatnikCopyScripts", "[", 
   StyleBox["dir", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "591f1930-1d08-4d99-82df-d607a601f15b"],
 "\[LineSeparator]copy paclet's scripts to ",
 Cell[BoxData[
  StyleBox["dir", "TI"]], "InlineFormula",ExpressionUUID->
  "ef9c0c35-aa57-441d-98ca-5e7d9189f885"],
 " and make them executable.\n",
 Cell["   ", "ModInfo",ExpressionUUID->"aae8b411-d516-417f-ad33-e259078d645f"],
 Cell[BoxData[
  RowBox[{"ChatnikCopyScripts", "[", "]"}]], "InlineFormula",ExpressionUUID->
  "1ea2541e-d6af-4a7f-b24f-fb343c243d36"],
 "\[LineSeparator]copy to the default \"applications\" directory."
}], "Usage",
 CellChangeTimes->{{3.987410043970297*^9, 3.987410106907734*^9}, {
  3.987410202774928*^9, 3.987410203115736*^9}},
 CellID->1966350706,ExpressionUUID->"ca4d2936-d046-4e69-8b0b-21dd1f50c386"],

Cell[TextData[{
 "This function copies paclet's scripts -- ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"LLMChat", ".", "wls"}], ",", " ", 
   RowBox[{"LLMChatMeta", ".", "wls"}], ",", 
   RowBox[{"LLMPrompt", ".", "wls"}]}]], "InlineFormula",ExpressionUUID->
  "96c62434-4b47-46ba-bb10-5ae92f6840eb"],
 " -- to directory for easier access."
}], "Notes",
 CellChangeTimes->{{3.987410121020791*^9, 3.987410144557235*^9}, {
  3.987410205788846*^9, 3.9874103034988747`*^9}},
 CellID->2057561650,ExpressionUUID->"071dc247-3f4e-46d0-aac4-de0726ffbe81"],

Cell["\<\
Optionally, the extensions \".wls\" can be removed and correspond Operating \
System (OS) Shell aliases can be created.\
\>", "Notes",
 CellChangeTimes->{{3.9874103043390093`*^9, 3.987410380391418*^9}},
 CellID->1267211895,ExpressionUUID->"e93f457b-0984-4404-aaec-0986c6680663"],

Cell["Currently, the functions works only the MacOSX.", "Notes",
 CellChangeTimes->{{3.9874103043390093`*^9, 3.987410383301344*^9}},
 FontWeight->"Bold",
 FontSlant->"Italic",
 CellID->307452252,ExpressionUUID->"5d8b2e84-db4b-4d96-9a8e-af2c2e7d92cd"],

Cell["The following options can be given: ", "Notes",
 CellID->830472059,ExpressionUUID->"b6ffa83d-070b-4ee4-af6c-3577b8932539"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "decbcc78-a03d-4c34-b1f3-b6885af4c46d"], "\"\<DropExtensions\>\"", 
    ButtonBox["True",
     BaseStyle->"Link"], Cell[
    "whether to drop the extensions or not", "TableText",ExpressionUUID->
     "7562183a-a451-4547-9a98-14fe75f4268e"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "c0c915a1-837b-4799-979c-7048652c4460"], "\"\<Aliases\>\"", 
    ButtonBox["False",
     BaseStyle->"Link"], Cell[
    "whether to make Shell aliases for the copied scripts", "TableText",
     ExpressionUUID->"c7c3a072-576b-4e46-aca3-61c9ac04365e"]}
  }]], "3ColumnTableMod",
