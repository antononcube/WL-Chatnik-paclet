Notebook[{

Cell[CellGroupData[{
Cell["ScrapePromptRecords", "ObjectName",
 CellID->1979369122,ExpressionUUID->"7d481663-fb7f-47b5-868e-94e513e7a4e1"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"091d7857-c223-4b6f-b6ae-e720aa33a67f"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["ScrapePromptRecords",
    BaseStyle->"Link",
    ButtonData->"paclet:AntonAntonovChatnik/ref/ScrapePromptRecords"], "[", 
   StyleBox["url", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "264dec6e-076b-4b24-8da1-a60dcc834ca8"],
 "\[LineSeparator]scrapes LLM prompt names and short descriptions at a given ",
 Cell[BoxData[
  StyleBox["url", "TI"]], "InlineFormula",ExpressionUUID->
  "8b3419a2-f2c7-4fed-a3a3-a8db64d0a5d0"],
 " location.\n\n",
 Cell["   ", "ModInfo",ExpressionUUID->"afa06d44-cb1f-4dd6-8f62-95e7e988fb89"],
 Cell[BoxData[
  RowBox[{"ScrapePromptRecords", "[", "]"}]], "InlineFormula",ExpressionUUID->
  "8cd8faf0-b8b5-4741-8da2-e362bfb3872a"],
 "\[LineSeparator]uses the ",
 ButtonBox["Wolfram Prompt Repository",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://resources.wolframcloud.com/PromptRepository/"], None},
  ButtonNote->"https://resources.wolframcloud.com/PromptRepository/"],
 "."
}], "Usage",
 CellChangeTimes->{
  3.987371726942204*^9, {3.987373019221889*^9, 3.9873731104147463`*^9}},
 CellID->587657777,ExpressionUUID->"a6671f3d-b123-4e32-b698-1b5dcbbfed8d"],

Cell["\<\
Since there is no a \"prompt search\" function (using, say, a regex), this \
scraper is used to endow the paclet with some LLM-prompts knowledge.\
\>", "Notes",
 CellChangeTimes->{{3.987373112458921*^9, 3.98737319941747*^9}},
 CellID->486965486,ExpressionUUID->"c648f394-91e2-4582-bcdb-b6370b66beca"]
}, Open  ]],

