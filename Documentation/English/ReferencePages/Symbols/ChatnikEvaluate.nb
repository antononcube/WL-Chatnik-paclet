 CellID->717635896,ExpressionUUID->"d017e52f-702d-43c1-ba6f-084c3b8b42d3"],

Cell["\<\
Evaluates a message input for given chat-ID and LLM-configuration options.\
\>", "Notes",
 CellChangeTimes->{{3.987372201396227*^9, 3.987372251094166*^9}},
 CellID->380938405,ExpressionUUID->"aa257dd2-2a50-4e1c-a0e1-aceab440675f"],

Cell["\<\
If the chat-ID corresponds to a known, persistent chat-object, then that \
object is used.\
\>", "Notes",
 CellChangeTimes->{{3.987372201396227*^9, 3.987372281499136*^9}},
 CellID->81962980,ExpressionUUID->"6cba795c-9a12-4aac-8598-1446d4652aa4"],

Cell["\<\
The persistent chat objects are stored as an association at a specified \
location. (\"Local\" by default.)\
\>", "Notes",
 CellChangeTimes->{{3.987372201396227*^9, 3.987372302710772*^9}, {
  3.9873726589969273`*^9, 3.9873726589985933`*^9}},
 CellID->1624978631,ExpressionUUID->"f3ee69f1-d046-4978-8889-4689ea1d81f4"],

Cell["\<\
The primary uses of this function is to be used with Command Line Arguments \
(CLI).\
\>", "Notes",
 CellChangeTimes->{{3.987372201396227*^9, 3.987372302710772*^9}, {
  3.987372659538724*^9, 3.987372689264804*^9}},
 CellID->1388319992,ExpressionUUID->"cdab0f86-b0e0-4aaa-922a-a94af28a30a6"],

Cell["The following options can be given: ", "Notes",
 CellID->476365066,ExpressionUUID->"fb89c976-b679-4584-af8b-76852d770895"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "f3fb473b-839b-4072-908a-4dfac2daa4d8"], "\"\<Location\>\"", \
"\"\<Local\>\"", Cell[
    "persistence storage location", "TableText",ExpressionUUID->
     "1ec881a4-5161-4500-8790-b15318598928"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "ec818424-9cdb-4c04-93e0-95020377c9f7"], "\"\<Echo\>\"", 
    ButtonBox["False",
     BaseStyle->"Link"], Cell[
    "whether to echo intermediate results or not", "TableText",ExpressionUUID->
     "5ec4f0d1-f24b-4db7-acb7-a5a2e5b3a0b7"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "fcee19a4-fdb9-42bd-aab5-dfa016ed4e68"], "\"\<ProgressReporting\>\"", 
    ButtonBox["False",
     BaseStyle->"Link"], Cell[
