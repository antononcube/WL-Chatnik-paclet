Cell[CellGroupData[{
Cell["ChatnikEvaluate", "ObjectName",
 CellID->121111367,ExpressionUUID->"7a5bac9e-0fe1-4657-b7c6-c631466f87d7"],

Cell[TextData[{
 Cell[" ", "ModInfo",ExpressionUUID->"69fcdce3-a3a6-4f41-847d-9f1c9050be7c"],
 Cell[BoxData[
  RowBox[{"ChatnikEvaluate", "[", 
   RowBox[{
    StyleBox["input", "TI"], ",", 
    StyleBox["cliArgs", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "e523f3d5-b0af-47f6-8b03-35cfc040c062"],
 "\[LineSeparator]evaluate the ",
 Cell[BoxData[
  StyleBox["input", "TI"]], "InlineFormula",ExpressionUUID->
  "87fed518-d85b-401e-9638-9006bce30527"],
 " message with a chat object specified with ",
 Cell[BoxData[
  StyleBox["cliArgs", "TI"]], "InlineFormula",ExpressionUUID->
  "04b01039-f5be-49d6-bceb-532baa9abffd"],
 ".\n",
 Cell["   ", "ModInfo",ExpressionUUID->"8685808e-8b76-4437-9936-19a873a64db0"],
