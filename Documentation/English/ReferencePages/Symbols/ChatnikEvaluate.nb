   StyleBox["cliLine", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "bef134e4-a3b4-4629-9656-9150bdd1b41f"],
 "\[LineSeparator]parse the command line arguments into an input and options \
association first."
}], "Usage",
 CellChangeTimes->{
  3.987371727874275*^9, 3.9873721949563007`*^9, {3.9873726974589376`*^9, 
   3.987372935530282*^9}},
 CellID->1851731460,ExpressionUUID->"db44c521-7611-43fc-a5e9-a56ecde731aa"],

Cell["", "Notes",
