Cell["Show persistent chat objects \"database\" (an association):", \
"ExampleText",
 CellChangeTimes->{{3.987372437696154*^9, 3.9873724634685097`*^9}},
 CellID->678487229,ExpressionUUID->"62ffa162-97b7-4839-abd9-5ee41e61c6f0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Shallow", "/@", 
  RowBox[{"PersistentSymbol", "[", "\"\<ChatnikChats\>\"", "]"}]}]], "Input",
 CellChangeTimes->{{3.987372469346746*^9, 3.98737248070098*^9}},
 CellLabel->"In[11]:=",
 CellID->1064654891,ExpressionUUID->"66c4bd5e-6c05-4621-b55c-9b517af44e2c"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{"\<\"yoda1\"\>", "\[Rule]", 
   TemplateBox[{"ChatObject", "\"[\[Ellipsis]]\""},
    "RowDefault"]}], "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{{3.987372465996254*^9, 3.987372481234693*^9}},
 CellLabel->"Out[11]=",
 CellID->1160428244,ExpressionUUID->"0f36eb13-e105-47c7-abbe-26e8accfa52e"]
}, Open  ]],

Cell["Continue the conversation with \"yoda1\":", "ExampleText",
 CellChangeTimes->{{3.987372490975924*^9, 3.987372503383338*^9}},
 CellID->2018498501,ExpressionUUID->"788c2f4d-bade-4b90-8056-dfa266531f00"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ChatnikEvaluate", "[", 
  RowBox[{"{", 
   RowBox[{"\"\<How many planets have you visited?\>\"", 
    ",", "\"\<--chat-id=yoda1\>\""}], "}"}], "]"}]], "Input",
 CellChangeTimes->{{3.987372506595648*^9, 3.987372526169804*^9}, {
  3.987372556890534*^9, 3.987372558404139*^9}, {3.98737263711862*^9, 
  3.9873726493230553`*^9}},
 CellLabel->"In[14]:=",
 CellID->2054856669,ExpressionUUID->"337690cb-1d82-4109-abc8-55e084d9c556"],

Cell[BoxData["\<\"Hmm, many planets I have seen. Countless worlds across the \
galaxy, hmm. Dagobah, my home, mysterious it is. Coruscant, the Jedi Temple \
there lies. Mustafar, volcanic and harsh, I have visited. Travel far, Jedi \
do. Wisdom in many places found, yes. The number, exact it is not, hmmm. \
Adventure, always part of the journey it is. Mmm.\"\>"], "Output",
 CellChangeTimes->{3.9873725272913933`*^9, 3.9873725590979652`*^9, 
  3.987372655201152*^9},
 CellLabel->"Out[14]=",
 CellID->2076789298,ExpressionUUID->"aa4569cc-fa1b-445e-a6d5-c534255d17d3"]
}, Open  ]]
}, Open  ]],

