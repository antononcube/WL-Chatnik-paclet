Cell[CellGroupData[{

Cell["Chat objects management ", "Subsubsection",
 TaggingRules->{},
 CellChangeTimes->{{3.9873309146878347`*^9, 3.987330921139737*^9}},
 CellID->1323273837,ExpressionUUID->"0dcb3e55-3a13-407a-bd23-492a21676833"],

Cell["\<\
The script \"LLMChatMeta\" is used to manage the chat objects. Here is its \
usage message:\
\>", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.987410561439701*^9, 3.9874106197188263`*^9}, {
  3.9874154710624123`*^9, 3.987415471492517*^9}, {3.9875416197357264`*^9, 
  3.987541620245949*^9}},
 CellID->12581532,ExpressionUUID->"6056f329-21de-483f-9f37-85b83004690d"],

Cell["\<\
LLMChatMeta --help

# Chat with persistent LLM-chat objects.
# 
# * Mandatory positional arguments:
# NAME       DOCUMENTATION
# command    Command, one of: card, clear, context, delete, file, \
first-message, last-message, list, load-llm-personas, message, messages.
# 
# * Optional arguments (must be passed as --name=... in any order):
# NAME       DEFAULT      DOCUMENTATION
# chat-id                 Chat ID.
# all        false        Whether to apply the command to all chat objects or \
not.
# n          -Infinity    Messages to clear. (For 'clear' and 'messages' only.)
# index      -1           Message index. (For 'message' only)
# format                  Format of the result. (For 'list' and 'context' \
only.)\
\>", "ExternalLanguage",
