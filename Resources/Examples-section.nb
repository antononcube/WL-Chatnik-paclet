Cell["Installation MacOSX & Linux", "Subsubsection",
 TaggingRules->{},
 CellChangeTimes->{{3.987331368519368*^9, 3.9873313731528397`*^9}, {
  3.987409858758325*^9, 3.987409871388185*^9}, {3.9874151685316353`*^9, 
  3.9874151698817453`*^9}, {3.987415247212759*^9, 3.9874152487988367`*^9}},
 CellID->462403203,ExpressionUUID->"042263ee-fd75-4ed0-a787-06e69edd2f46"],

Cell[TextData[{
 "Copy paclet's scripts to a directory that is already in shell's ",
 Cell[BoxData["PATH"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b6290776-1b8c-4312-bdf7-7f62a447916b"],
 " variable. For example, \"~/.local/bin\":"
}], "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.9874049386711893`*^9, 3.9874049503698463`*^9}, {
  3.987409756665781*^9, 3.9874097953413973`*^9}, {3.987415184011919*^9, 
  3.987415239466524*^9}},
 CellID->1379475188,ExpressionUUID->"f49fff80-93b8-4a01-bf13-8bfa746ec61a"],

Cell[BoxData[
 RowBox[{"ChatnikCopyScripts", "[", "\"\<~/.local/bin\>\"", "]"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.9874152665444403`*^9, 3.9874152758440647`*^9}},
 CellID->463853030,ExpressionUUID->"c7f20117-a42c-4b9b-8c75-c6f0d0e7e510"],

Cell[TextData[{
 "On MacOSX if no directory is specified for ",
 Cell[BoxData[
  ButtonBox["ChatnikCopyScripts",
   BaseStyle->"Link",
   ButtonData->"paclet:AntonAntonov/Chatnik/ref/ChatnikCopyScripts"]], 
  "InlineFormula",ExpressionUUID->"57881d9f-c8d1-4c26-800d-0172cc6a175a"],
 " (i.e the directory is ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["Automatic", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/Automatic",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2e03a113-8be2-44aa-b25e-4a3ea3d71739"],
 ") then paclet's scripts are copied in the \"~/Applications\" directory:"
}], "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.9874049386711893`*^9, 3.9874049503698463`*^9}, {
   3.987409756665781*^9, 3.9874097953413973`*^9}, {3.987415282173305*^9, 
   3.987415344397828*^9}, 3.987415947791066*^9, {3.987584083007721*^9, 
   3.987584083495426*^9}},
 CellID->48958861,ExpressionUUID->"4bfb15f2-9776-4fbb-92aa-9266dca418f3"],

Cell[BoxData[
 RowBox[{"ChatnikCopyScripts", "[", "]"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.987409801203108*^9, 3.9874098084603043`*^9}},
 CellID->1296780026,ExpressionUUID->"5e2439d8-b73c-4974-89e9-758e98eb3286"]
}, Open  ]],

