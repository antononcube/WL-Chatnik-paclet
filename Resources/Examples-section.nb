Cell[CellGroupData[{

Cell["Basic Examples", "Subsection",
 TaggingRules->{},
 CellID->816121734,ExpressionUUID->"6e40844a-ec8f-421c-b30f-5157705241bd"],

Cell[TextData[{
 "The script \"LLMChat\" is used to interact with the chat objects. Create \
and chat with an LLM persona named \"yoda1\" (using the ",
 ButtonBox["Yoda chat persona",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://resources.wolframcloud.com/PromptRepository/resources/Yoda"],
     None},
  ButtonNote->
   "https://resources.wolframcloud.com/PromptRepository/resources/Yoda"],
 "):"
}], "Text",
 TaggingRules->{},
 CellChangeTimes->{
  3.98733039275891*^9, {3.9873304296639643`*^9, 3.9873304296642*^9}, {
   3.987541639224131*^9, 3.987541667452157*^9}},
 CellTags->"DefaultContent",
 CellID->489008670,ExpressionUUID->"bd421ae9-bff1-440f-9f8f-c8c48339b10b"],

