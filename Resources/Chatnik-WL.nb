Cell[TextData[{
 StyleBox["Remark:",
  FontWeight->"Bold"],
 " Instead of the (",
 ButtonBox["buggy",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://mathematica.stackexchange.com/a/204022"], None},
  ButtonNote->"https://mathematica.stackexchange.com/a/204022"],
 ") ",
 StyleBox["$ScriptInputString", "Program"],
 ", the shell pipeline value was obtained with ",
 StyleBox["Import[\[OpenCurlyDoubleQuote]!cat\[CloseCurlyDoubleQuote], \
\[OpenCurlyDoubleQuote]String\[CloseCurlyDoubleQuote]]", "Program"],
 "."
}], "Text",
 CellChangeTimes->{{3.987539544470728*^9, 3.9875395915705442`*^9}, {
  3.9875397599651747`*^9, 
  3.9875397599656363`*^9}},ExpressionUUID->"01f5746f-a1f7-4080-bf1e-\
ca28f62a58a0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Make a request, echo, and place in clipboard", "Subsection",ExpressionUUID->"8f262bec-a859-4901-a084-96b4801875d9"],

Cell[TextData[{
 "This command works on MacOSX the shells of which have the program ",
 StyleBox["pbcopy", "Program"],
 ":"
}], "Text",
 CellChangeTimes->{{3.987538428677147*^9, 
  3.9875384828128147`*^9}},ExpressionUUID->"b8241d86-9d27-4177-8471-\
387abac06f6d"],

Cell["\<\
LLMChat -i=unix '@CodeWriterX|Shell macOS list of files echo the result and \
copy to clipboard.' | tee /dev/tty | pbcopy\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"f18ebb94-58d7-462f-90d0-37ae30ef3882"],

Cell["#  ls | tee >(pbcopy)", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"60fffc35-432a-4823-9d45-2325053d255c"],

Cell[TextData[{
 StyleBox["Remark:",
  FontWeight->"Bold"],
 " Instead of ",
 StyleBox["... | tee /dev/tty | pbcopy", "Program"],
 " the pipeline command ",
 StyleBox["... | tee >(pbcopy)", "Program"],
 " can be also used."
}], "Text",
 CellChangeTimes->{{3.987538799151753*^9, 
  3.987538815397334*^9}},ExpressionUUID->"4932f8ff-8ba1-45db-bf6c-\
886dce3da893"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Make a mind-map of a file", "Subsection",ExpressionUUID->"0a1d4360-bcc9-4e03-92a4-d9b256a1dc94"],

Cell["\<\
Consider the task of making an (LLM derived) mind map over a certain \
document. (Say, this REDME.) There are several ways to do that.\
\>", "Text",ExpressionUUID->"9a73ce0b-85e9-4384-bc2e-d52154bbc704"],

Cell[CellGroupData[{

Cell["1", "Subsubsection",ExpressionUUID->"68045bac-ba5e-47c6-b72c-596b306b44bb"],

Cell["Put file's content to be the positional input argument", "ItemNumbered",ExpressionUUID->"4e0215d2-d329-4492-8b16-4d1cbfc77e14"],

Cell[CellGroupData[{

Cell[TextData[{
 "Use",
 " ",
 "the",
 " ",
 "prompt",
 " ",
 ButtonBox["\"MermaidDiagram\"",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://resources.wolframcloud.com/PromptRepository/resources/\
MermaidDiagram/"], None}],
 " ",
 "in",
 " ",
 StyleBox["--prompt", "Program"]
}], "ItemNumbered",ExpressionUUID->"f678f390-2b75-4a6c-9dc7-0bdc90c079e5"],

Cell["\<\
LLMChat \"$(cat README.md)\" --i=mmd --model=ollama::gemma4:26b \
--prompt=@MermaidDiagram\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"4306bd84-4fe2-4d9f-9dce-bed15585efc0"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["2", "Subsubsection",ExpressionUUID->"e353ab2d-794a-4645-b2bd-e1b9242bd6bf"],

Cell["Put file's content to be the positional input argument", "ItemNumbered",ExpressionUUID->"9207b240-43b9-4023-9aa2-c71b03471039"],

Cell[CellGroupData[{

Cell[TextData[{
 "Expand",
 " ",
 "the",
 " ",
 "prompt",
 " ",
 "\"manually\"",
 " ",
 "via",
 " ",
 StyleBox["LLMPrompt", "Program"],
 " ",
 "provided",
 " ",
 "by",
 " ",
 "\"Chatnik\"."
}], "ItemNumbered",ExpressionUUID->"59b146b8-b21d-4170-81df-9ca7fd7ef14d"],

Cell["\<\
LLMChat \"$(cat README.md)\" --i=mmd --model=ollama::gemma4:26b \
--prompt=\"$(LLMPrompt MermaidDiagram below)\"\
\>", "ExternalLanguage",
 CellEvaluationLanguage->"Shell",
 CellChangeTimes->{{3.98753873145789*^9, 
  3.987538732880973*^9}},ExpressionUUID->"3660cbcf-081f-4a0a-a524-\
3484c84ef1fe"]
}, Open  ]],

Cell[TextData[{
 StyleBox["Remark:",
  FontWeight->"Bold"],
 " ",
 "This",
 " ",
 "example",
 " ",
 "shows",
 " ",
 "another",
 " ",
 "computation",
 " ",
 "result",
 " ",
 "can",
 " ",
 "be",
 " ",
 "used",
 " ",
 "as",
 " ",
 "a",
 " ",
 "prompt.",
 " ",
 "I.e.",
 " ",
 "no",
 " ",
 "need",
 " ",
 "to",
 " ",
 "rely",
 " ",
 "on",
 " ",
 "the",
 " ",
 "automatic",
 " ",
 "prompt",
 " ",
 "expansion."
}], "Text",ExpressionUUID->"f42360af-25a4-4676-b0b8-693f2dd7c1c8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3", "Subsubsection",ExpressionUUID->"c76db744-0ec2-4ec6-b3cd-3ea49dd7b893"],

Cell[TextData[{
 "Give",
 " ",
 "the",
 " ",
 "prompt",
 " ",
 ButtonBox["\"MermaidDiagram\"",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://resources.wolframcloud.com/PromptRepository/resources/\
MermaidDiagram/"], None}],
 " ",
 "as",
 " ",
 "input"
}], "ItemNumbered",ExpressionUUID->"1c773e10-2a96-4e62-972d-23dc797bcfc9"],

Cell[CellGroupData[{

Cell[TextData[{
 "Put",
 " ",
 "file's",
 " ",
 "content",
 " ",
 "to",
 " ",
 "be",
 " ",
 "the",
 " ",
 "value",
 " ",
 "of",
 " ",
 StyleBox["--prompt", "Program"]
}], "ItemNumbered",ExpressionUUID->"19365deb-6a28-4488-b7d6-afce5a40a6b9"],

Cell[CellGroupData[{

Cell["Put additional prompting for further interaction", "Subsubitem",ExpressionUUID->"9afea2c0-af44-4520-b88f-46ce60c1efbb"],

Cell["\<\
LLMChat @MermaidDiagram --i=mmd  --model=ollama::gemma4:26b --prompt=\"FOCUS \
TEXT START:: $(cat README.md) ::END OF FOCUS TEXT. If it is not clear which \
text to use, use FOCUS TEXT.\"\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"eaf8e823-4606-430c-b1b5-77cf6edb322e"]
}, Open  ]]
}, Open  ]],

Cell["\<\
This command allows to do further tasks with the file content as context. For \
example:\
\>", "Text",ExpressionUUID->"6acf6ab8-6894-4f72-b6b9-6ca65a6af4df"],

Cell["LLMChat '!ThinkingHatsFeedback' --i=mmd", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"13acccd6-d06a-4281-8166-708a87e26920"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Result", "Subsubsection",ExpressionUUID->"48a9f91e-610f-4bf4-90e1-081c2438e490"],

Cell["The commands above produce results similar to this diagram:", "Text",ExpressionUUID->"86d40e9e-81ac-4f3f-bdc5-9a58e35a9990"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ResourceFunction", "[", "\"\<MermaidInk\>\"", "]"}], 
  "[", "\"\<\nmindmap\n  root(\\\"Chatnik\\\")\n    Purpose\n      Python \
package\n      CLI for LLM personas\n      Persistent interaction via OS \
files\n    Features\n      Multiple LLM providers\n      LLM Prompts \
integration\n      OS shell access\n    LLM Access\n      Ollama\n      \
Llamafile\n      Service Providers\n        OpenAI\n        Gemini\n        \
MistralAI\n    Scripts\n      LLMChat\n      LLMChatMeta\n        List chats\n\
        Manage messages\n        Delete chats\n    Installation\n      Zef \
Ecosystem\n      GitHub\n\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.987527558302856*^9, 3.987527582269342*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"6d6126ba-3c9c-480a-9146-9d5132692ed4"],

