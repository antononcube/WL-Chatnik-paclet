Cell[CellGroupData[{

Cell["Chat objects management", "Section",ExpressionUUID->"199c7a73-ac6a-4ba4-af00-45c597a9f92b"],

Cell[TextData[{
 "The",
 " ",
 "CLI",
 " ",
 "script",
 " ",
 StyleBox["LLMChatMeta", "Program"],
 " ",
 "can",
 " ",
 "be",
 " ",
 "used",
 " ",
 "to",
 " ",
 "view",
 " ",
 "and",
 " ",
 "manage",
 " ",
 "the",
 " ",
 "chat",
 " ",
 "objects",
 " ",
 "used",
 " ",
 "by",
 " ",
 "\"Chatnik\".",
 " ",
 "Here",
 " ",
 "is",
 " ",
 "its",
 " ",
 "usage",
 " ",
 "message:"
}], "Text",ExpressionUUID->"356826a2-3d2b-457a-af6e-c51c6e95140a"],

Cell["LLMChatMeta --help", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"874305a5-7e5f-4b72-b3f8-e9117c921dd3"],

Cell["\<\
# Chat with persistent LLM-chat objects.
# 
# * Mandatory positional arguments:
# NAME       DOCUMENTATION
# command    Command, one of: card, clear, context, delete, file, \
first-message, last-message, list, load-llm-personas, message, messages.
# 
# * Optional arguments (must be passed as --name=... in any order):
# NAME       DEFAULT      DOCUMENTATION
# chat-id                 Chat ID.
# id                      Chat ID. (Ignored if --chat-id is present.)
# i                       Chat ID. (Ignored if --chat-id or --id are \
present.)
# all        false        Whether to apply the command to all chat objects or \
not.
# n          -Infinity    Messages to clear. (For 'clear' and 'messages' only.)
# index      -1           Message index. (For 'message' only)
# format                  Format of the result. (For 'list' and 'context' \
only.)\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"0d6da9fb-3643-4de2-92b7-51a5bd04f0a0"],

Cell["\<\
List all chat objects (\"chats\" and \"personas\" are synonyms to \"list\"):\
\>", "Text",ExpressionUUID->"db3e8715-b7bc-4354-ae06-5f8c4a62ec43"],

Cell["LLMChatMeta list --format=json", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"3dc9bb91-74fc-4556-aceb-5620f2185a9b"],

Cell["\<\
# {
# \t\"yoda1\":{
# \t\t\"ChatID\":\"86bdeddf-b157-47e6-ba24-254ae8759f13\",
# \t\t\"Messages\":5,
# \t\t\"LLMConfiguration\":{
# \t\t\t\"Service\":\"OpenAI\",
# \t\t\t\"Name\":\"gpt-4.1-mini\"
# \t\t},
# \t\t\"Usage\":\"193 tokens\"
# \t}
# }\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"b71db799-70b1-4598-81bd-cd9b9f0db576"],

Cell["Here we see the messages of \"yoda1\":", "Text",ExpressionUUID->"5874836f-7f2c-4e74-9401-759ce2e2f271"],

Cell["LLMChatMeta messages --i=yoda1", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"a6d363af-66b0-4043-9d82-2cd08fb1c415"],

Cell["\<\
# You are Yoda. 
# Respond to ALL inputs in the voice of Yoda from Star Wars. 
# Be sure to ALWAYS use his distinctive style and syntax. Vary sentence length.
# 
# hi who are you?
# 
# Yoda, I am. Wise, old Jedi Master, yes. Guide you, I can. Hmmm. Learn from \
the Force, you must. Help you, I will. What seek, do you?
# 
# since when do you use a green light saber?
# 
# Green, my lightsaber is, yes. For Jedi Consulars, it is common, hmmm. \
Skilled in the Force and diplomacy, I am. Since my training as a Jedi, long \
ago, have I carried this blade. Strong in the Force, the color of the saber \
shows, yes. Questions have you more? Ask, you should.\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"0837b1fa-3bc3-4458-8747-518a0f1f6047"],

Cell["Here we clear the messages:", "Text",ExpressionUUID->"fe0b0dee-0ecb-46a9-a213-850e6ded293d"],

Cell["LLMChatMeta clear --i=yoda1", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"bee428de-6150-42ce-9bcd-dc05051b1e11"],

Cell["# Cleared the messages from 1 to 5 of chat object yoda1.", \
"ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"8ce9dc65-c978-4504-8a96-f0172a5a304c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Advanced usage examples", "Section",ExpressionUUID->"7974485f-cacc-4ff6-906c-76368e2314ae"],

Cell[CellGroupData[{

Cell["Asking for a result in specific format", "Subsection",ExpressionUUID->"46b5f986-6dbf-45b8-a746-e11baad9e9ab"],

Cell["\<\
LLMChat 'What are the populations of the Brazilian states? \
#NothingElse|\"JSON data frame\"' --i=beta --model=gpt-4.1-mini\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"a18fa8ec-bc9a-48ef-85f5-ce3c93e8afbb"],

Cell["\<\
# ```json
# {
#   \"Acre\": 906876,
#   \"Alagoas\": 3351543,
#   \"Amap\[AAcute]\": 861773,
#   \"Amazonas\": 4269603,
#   \"Bahia\": 14812617,
#   \"Cear\[AAcute]\": 9187103,
#   \"Distrito Federal\": 3015268,
#   \"Esp\[IAcute]rito Santo\": 4064052,
#   \"Goi\[AAcute]s\": 7294056,
#   \"Maranh\[ATilde]o\": 7075181,
#   \"Mato Grosso\": 3526220,
#   \"Mato Grosso do Sul\": 2778986,
#   \"Minas Gerais\": 21168791,
#   \"Par\[AAcute]\": 8602865,
#   \"Para\[IAcute]ba\": 4039277,
#   \"Paran\[AAcute]\": 11433957,
#   \"Pernambuco\": 9557071,
#   \"Piau\[IAcute]\": 3273227,
#   \"Rio de Janeiro\": 17463349,
#   \"Rio Grande do Norte\": 3506853,
#   \"Rio Grande do Sul\": 11329605,
#   \"Rond\[OHat]nia\": 1820329,
#   \"Roraima\": 631181,
#   \"Santa Catarina\": 7660443,
#   \"S\[ATilde]o Paulo\": 46289333,
#   \"Sergipe\": 2298696,
#   \"Tocantins\": 1590248
# }
# ```\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"28dc573c-59fa-4d13-ad73-629ec3effb4b"],

Cell["\<\
Further we can make an image from that JSON result using a pipeline that:\
\>", "Text",
 CellChangeTimes->{{3.987539394932556*^9, 
  3.987539452157864*^9}},ExpressionUUID->"4ed7dd52-e99a-4782-9337-\
9603f52cd2b5"],

Cell["Takes the last message of the chat object \[OpenCurlyDoubleQuote]beta\
\[CloseCurlyDoubleQuote]", "Item",
 CellChangeTimes->{{3.987539456315113*^9, 
  3.987539483033733*^9}},ExpressionUUID->"c0a9bc95-6f14-44e9-804d-\
cf935af06cb3"],

Cell["\<\
Removes the first and last lines (which are Markdown code block fences)\
\>", "Item",
 CellChangeTimes->{{3.987539456315113*^9, 
  3.9875395199809732`*^9}},ExpressionUUID->"a6134538-383c-40c8-bc39-\
684a18c38cb5"],

Cell[CellGroupData[{

Cell[TextData[{
 "Make a list plot with Wolfram Language (using ",
 StyleBox[ButtonBox["wolframscript",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/ref/program/wolframscript.\
html"], None},
  ButtonNote->
   "https://reference.wolfram.com/language/ref/program/wolframscript.html"], 
  "Program"],
 ")"
}], "Item",
 CellChangeTimes->{{3.987539456315113*^9, 3.987539519152742*^9}, {
  3.987539614162489*^9, 3.987539638308744*^9}, {3.987539669456936*^9, 
  3.9875396694574013`*^9}},ExpressionUUID->"8e75043d-825f-4959-bc9f-\
91eef2cc772f"],

Cell["\<\
 LLMChatMeta last-message --i=beta | sed '1d; $d' | wolframscript -code \
'gr=ImportString[Import[\"!cat\", \
\"String\"],\"RawJSON\"]//ReverseSort//ListPlot[#, ImageSize->600, PlotTheme \
-> \"Detailed\", PlotRange->All]&; Export[\"./beta.png\", gr]' && open \
./beta.png \
\>", "ExternalLanguage",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Shell", "SessionID" -> "default-shell-session", "Evaluator" -> 
     Automatic|>|>,
 CellEvaluationLanguage->"Shell",
 CellChangeTimes->{{3.987539417260264*^9, 
  3.987539421978003*^9}},ExpressionUUID->"eab1b9fd-857d-4aae-9f5f-\
677a347a5f8a"],

