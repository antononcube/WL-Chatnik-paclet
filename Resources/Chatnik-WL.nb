Cell[CellGroupData[{
Cell["A concise guide to the \[OpenCurlyDoubleQuote]Chatnik\
\[CloseCurlyDoubleQuote] system", "Title",
 CellChangeTimes->{{3.9875407569505987`*^9, 3.9875407671501226`*^9}, {
  3.9875409210231247`*^9, 3.987540928087841*^9}, {3.987541130789613*^9, 
  3.987541132092989*^9}},ExpressionUUID->"011a8398-0f56-4b92-baa0-\
aa140215c037"],

Cell[CellGroupData[{

Cell["Introduction", "Section",
 CellChangeTimes->{{3.987540916450264*^9, 
  3.9875409181409683`*^9}},ExpressionUUID->"30e87f0f-6399-4552-8fcc-\
8a2312f35102"],

Cell["\<\
\[OpenCurlyDoubleQuote]Chatnik\[CloseCurlyDoubleQuote] is a Wolfram Language \
paclet that provides Command Line Interface (CLI) scripts for conversing with \
persistent Large Language Model (LLM) personas.\
\>", "Text",
 CellChangeTimes->{{3.9875402604267797`*^9, 
  3.987540269561351*^9}},ExpressionUUID->"9f796c70-cc8b-4283-810c-\
8be7bf8563b4"],

Cell[TextData[{
 "\[OpenCurlyDoubleQuote]Chatnik\[CloseCurlyDoubleQuote] uses the ",
 ButtonBox["Wolfram Language persistent values functionalities",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/guide/PersistentStorage.html"]\
, None},
  ButtonNote->
   "https://reference.wolfram.com/language/guide/PersistentStorage.html"],
 " in order to maintain persistent interaction with multiple LLM chat objects."
}], "Text",
 CellChangeTimes->{{3.9875831717431192`*^9, 
  3.987583172449663*^9}},ExpressionUUID->"8db2025e-2782-4685-9887-\
e79de5d95b26"],

