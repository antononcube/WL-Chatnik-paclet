Cell[CellGroupData[{

Cell["Persistent chat objects", "Subsection",ExpressionUUID->"fc5baeae-68fd-41dc-882c-ca856d7b48c9"],

Cell[TextData[{
 "Keeping the persistent chat objects database is a fairly straightforward \
using the ",
 ButtonBox["Wolfram Language persistent values system",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://reference.wolfram.com/language/guide/SettingPersistentValues.\
html"], None}],
 " . Efficiency considerations for \"using the WL and OS to manage the \
database\" are probably not that important because LLMs invocation is (much) \
slower in comparison."
}], "Text",
 CellChangeTimes->{{3.987583645416882*^9, 
  3.987583645847692*^9}},ExpressionUUID->"58e05aee-41f2-465c-b144-\
6699b38dbaf9"]
}, Open  ]]
}, Open  ]],

