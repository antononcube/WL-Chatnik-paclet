  FontSlant->"Italic"],
 " ",
 "chat",
 " ",
 "with",
 " ",
 "an",
 " ",
 "LLM",
 " ",
 "persona",
 " ",
 "named",
 " ",
 "\"yoda1\"",
 " ",
 "(using",
 " ",
 "the",
 " ",
 ButtonBox["Yoda chat persona",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://resources.wolframcloud.com/PromptRepository/resources/Yoda/"]\
, None}],
 " ",
 "):"
}], "ItemNumbered",ExpressionUUID->"476c4a4c-1e63-4260-9d3f-f269fc297bcf"],

Cell["LLMChat 'hi who are you?' --i=yoda1 --prompt=@Yoda", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"d6d74556-6092-408c-9fc7-03887764dcb3"],

Cell["\<\
# Yoda, I am. Wise, old Jedi Master, yes. Guide you, I can. Hmmm. Learn from \
the Force, you must. Help you, I will. What seek, do you?\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"cb1057ff-87ea-4104-9b5a-f15c7247053d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Continue the conversation with \"yoda1\":", "ItemNumbered",ExpressionUUID->"b969d240-989d-4ae2-9693-9d1d8ae04ef6"],

Cell["\<\
LLMChat 'since when do you use a green light saber?' --i=yoda1\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"afdb6def-c73f-4371-a643-a8db5d1523fb"],

Cell["\<\
# Green, my lightsaber is, yes. For Jedi Consulars, it is common, hmmm. \
Skilled in the Force and diplomacy, I am. Since my training as a Jedi, long \
ago, have I carried this blade. Strong in the Force, the color of the saber \
shows, yes. Questions have you more? Ask, you should.\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"e38779cd-ea14-4c76-bbfb-67480a181e0b"]
}, Open  ]],

