Cell[CellGroupData[{

Cell["Customization", "Section",ExpressionUUID->"53a02b77-fa1a-4473-9a32-9a98aa49108c"],

Cell[CellGroupData[{

Cell["Default model", "Subsection",ExpressionUUID->"93f24507-7920-4913-8661-74b116e36594"],

Cell[TextData[{
 "Default model can be specified with the OS environmental variable ",
 StyleBox["CHATNIK_DEFAULT_MODEL", "Program"],
 " . For example:"
}], "Text",
 CellChangeTimes->{{3.987583582596417*^9, 
  3.987583587409886*^9}},ExpressionUUID->"b5d16fc2-6ae5-4624-bd05-\
72cccc3d7029"],

Cell["export CHATNIK_DEFAULT_MODEL=ollama::gemma4:26b", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"9b21695f-3915-461b-847e-411ef04d2717"],

Cell[TextData[{
 "Remove with ",
 StyleBox["unset CHATNIK_DEFAULT_MODEL", "Program"],
 "."
}], "Text",
 CellChangeTimes->{{3.987527512581607*^9, 
  3.9875275140808697`*^9}},ExpressionUUID->"1f5ca8c8-702c-4d9e-aa9d-\
7b8c200918d2"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Implementation details", "Section",ExpressionUUID->"ecf3afd7-bc88-4614-b0d1-ad5f2f7cd1bb"],

Cell[CellGroupData[{

Cell["Architectural design", "Subsection",ExpressionUUID->"cf73ed3d-e583-41b9-97d6-aaf837288f60"],

Cell["\<\
Here is a flowchart that describes the interaction between the host Operating \
System and chat objects database:\
\>", "Text",ExpressionUUID->"ce1d93ad-c18b-416f-acc4-a1e70b938600"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ResourceFunction", "[", "\"\<MermaidInk\>\"", "]"}], 
  "[", "\"\<\nflowchart TD\n    OpenAI{{OpenAI}}\n    Gemini{{Gemini}}\n    \
Ollama{{Ollama}}\n    LLMFunc[[ChatEvaluate]]\n    LLMProm[[LLMPrompt]]\n    \
CODBOS[(Persistent<br>Chat objects)]\n    CODB[(Chat objects)]\n    \
PDB[(Prompts)]\n    CCommand[/Chat command/]\n    CCommandOutput[/Chat \
result/]\n    CIDQ{Chat ID<br>specified?}\n    CIDEQ{Chat ID<br>exists in \
DB?}\n    IngestCODB[Chat objects file<br>ingestion]\n    UpdateCODB[Chat \
objects file<br>update]\n    RECO[Retrieve existing<br>chat object]\n    \
COEval[Message<br>evaluation]\n    PromParse[Prompt<br>DSL spec parsing]\n    \
KPFQ{Known<br>prompts<br>found?}\n    PromExp[Prompt<br>expansion]\n    \
CNCO[Create new<br>chat object]\n    CIDNone[\\\"Assume chat ID<br>is \
'NONE'\\\"] \n    subgraph \\\"OS Shell\\\"    \n        CCommand\n        \
CCommandOutput\n    end\n    subgraph OS file system\n        CODBOS\n    end\
\n    subgraph PromptProc[Prompt processing]\n        PDB\n        LLMProm\n  \
      PromParse\n        KPFQ\n        PromExp \n    end\n    subgraph \
LLMInteract[LLM interaction]\n      COEval\n      LLMFunc\n      Gemini\n     \
 OpenAI\n      Ollama\n    end\n    subgraph Chatnik backend\n        \
IngestCODB\n        CODB\n        CIDQ\n        CIDEQ\n        CIDNone\n      \
  RECO\n        CNCO\n        UpdateCODB\n        PromptProc\n        \
LLMInteract\n    end\n    CCommand --> IngestCODB\n    CODBOS -.-> IngestCODB \
\n    UpdateCODB -.-> CODBOS \n    IngestCODB -.-> CODB\n    IngestCODB --> \
CIDQ\n    CIDQ --> |yes| CIDEQ\n    CIDEQ --> |yes| RECO\n    RECO --> \
PromParse\n    COEval --> CCommandOutput\n    CIDEQ -.- CODB\n    CIDEQ --> \
|no| CNCO\n    LLMFunc -.- CNCO -.- CODB\n    CNCO --> PromParse --> KPFQ\n   \
 KPFQ --> |yes| PromExp\n    KPFQ --> |no| COEval\n    PromParse -.- LLMProm \
\n    PromExp -.- LLMProm\n    PromExp --> COEval \n    LLMProm -.- PDB\n    \
CIDQ --> |no| CIDNone\n    CIDNone --> CIDEQ\n    COEval -.- LLMFunc\n    \
COEval --> UpdateCODB\n    LLMFunc <-.-> OpenAI\n    LLMFunc <-.-> Gemini\n   \
 LLMFunc <-.-> Ollama\n\n    style PromptProc \
fill:LightBlue,stroke:#333,stroke-width:2px\n    style LLMInteract \
fill:LightBlue,stroke:#333,stroke-width:2px\n\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.987527296565793*^9, 3.987527321315877*^9}, {
  3.987527434824559*^9, 3.9875274591684237`*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"557d5f19-f92f-4049-bfe3-cb1cbfcf8f0f"],

