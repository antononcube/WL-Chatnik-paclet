Cell[CellGroupData[{

Cell["Render Markdown results with dedicated programs", "Subsection",ExpressionUUID->"33f22bd4-f992-4b2c-80ad-a1ee625396ac"],

Cell[TextData[{
 "Get",
 " ",
 "feedback",
 " ",
 "on",
 " ",
 "a",
 " ",
 "text",
 " ",
 "with",
 " ",
 "the",
 " ",
 "prompt",
 " ",
 ButtonBox["\"ThinkingHatsFeedback\"",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://resources.wolframcloud.com/PromptRepository/resources/\
ThinkingHatsFeedback"], None}],
 " ",
 ":"
}], "Text",ExpressionUUID->"f9d84df5-d288-4f29-b9fd-cc77ea808d81"],

Cell["\<\
cat README.md | LLMChat --i=th --prompt=\"$(llm-prompt ThinkingHatsFeedback \
'the TEXT is GIVEN BELOW.' --format=Markdown)\" --model=ollama::gemma4:26b\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"b0883092-154d-4139-9002-59cd63d9d749"],

Cell[TextData[{
 StyleBox["Remark:",
  FontWeight->"Bold"],
 " ",
 "By",
 " ",
 "default",
 " ",
 "the",
 " ",
 "prompt",
 " ",
 "\"ThinkingHatsFeedback\"",
 " ",
 "gives",
 " ",
 "the",
 " ",
 "hat-feedback",
 " ",
 "table",
 " ",
 "in",
 " ",
 "JSON",
 " ",
 "format.",
 " ",
 "(Currently)",
 " ",
 "the",
 " ",
 "prompt",
 " ",
 "expansion",
 " ",
 "does",
 " ",
 "not",
 " ",
 "handle",
 " ",
 "named",
 " ",
 "parameters,",
 " ",
 "hence,",
 " ",
 StyleBox["llm-prompt", "Program"],
 " ",
 "is",
 " ",
 "used",
 " ",
 "to",
 " ",
 "specify",
 " ",
 "the",
 " ",
 "Markdown",
 " ",
 "format",
 " ",
 "for",
 " ",
 "that",
 " ",
 "table."
}], "Text",ExpressionUUID->"b613e70b-255e-40ce-b11b-74389cd4ccab"],

Cell[TextData[{
 "Get",
 " ",
 "the",
 " ",
 "LLM",
 " ",
 "(chat",
 " ",
 "object)",
 " ",
 "answer",
 " ",
 "--",
 " ",
 "via",
 " ",
 StyleBox["LLMChatMeta", "Program"],
 " ",
 "--",
 " ",
 "put",
 " ",
 "into",
 " ",
 "a",
 " ",
 "temporary",
 " ",
 "file",
 " ",
 "and",
 " ",
 "\"system",
 " ",
 "open\"",
 " ",
 "that",
 " ",
 "file:"
}], "Text",ExpressionUUID->"9f5c452b-3310-4eaa-b312-314a3a1792ed"],

Cell["\<\
tmpfile=\"$TMPDIR/llmans.md\"; LLMChatMeta -i=th last-message > \"$tmpfile\"; \
open \"$tmpfile\"\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"69738e2e-279e-430b-be89-7c2b046d6b87"],

Cell[TextData[{
 "The",
 " ",
 "command",
 " ",
 "above",
 " ",
 "works",
 " ",
 "on",
 " ",
 "macOS.",
 " ",
 "On",
 " ",
 "Linux",
 " ",
 "instead",
 " ",
 "of",
 " ",
 "explicitly",
 " ",
 "creating",
 " ",
 "a",
 " ",
 "file",
 " ",
 "in",
 " ",
 "the",
 " ",
 "temporary",
 " ",
 "dictory,",
 " ",
 "the",
 " ",
 "argument",
 " ",
 StyleBox["--suffix", "Program"],
 " ",
 "can",
 " ",
 "be",
 " ",
 "passed",
 " ",
 "to",
 " ",
 StyleBox["mktemp", "Program"],
 " ",
 ".",
 " ",
 "For",
 " ",
 "example:"
}], "Text",ExpressionUUID->"3aa2bed5-f12d-427f-b4dd-e37a5fbc51c5"],

Cell["\<\
tmpfile=$(mktemp --suffix=\".md\"); LLMChatMeta last-message --i=th > \
\"$tmpfile\"; open \"$tmpfile\"\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"e0e74f96-6a5a-456f-91f2-42ae55ce45fd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tabulate the LLM personas summary", "Subsection",ExpressionUUID->"3caa169b-2882-4193-8275-757cd129ce31"],

Cell[TextData[{
 "If",
 " ",
 "the",
 " ",
 "text",
 " ",
 "browser",
 " ",
 ButtonBox["`w3m`",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://w3m.sourceforge.net"], None}],
 " ",
 "and",
 " ",
 "the",
 " ",
 "Raku",
 " ",
 "package",
 " ",
 ButtonBox["\"Data::Translators\"",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://raku.land/zef:antononcube/Data::Translators"], None}],
 " ",
 "are",
 " ",
 "installed,",
 " ",
 "the",
 " ",
 "following",
 " ",
 "pipeline",
 " ",
 "can",
 " ",
 "be",
 " ",
 "used",
 " ",
 "to",
 " ",
 "tabulate",
 " ",
 "the",
 " ",
 "summary",
 " ",
 "of",
 " ",
 "the",
 " ",
 "LLM",
 " ",
 "personas:"
}], "Text",ExpressionUUID->"46b71607-b225-447f-b1d4-649edc757605"],

Cell["\<\
LLMChatMeta list --format=json | data-translation | w3m -T text/html -dump \
-cols 120\
\>", "ExternalLanguage",
 CellEvaluationLanguage->
  "Shell",ExpressionUUID->"a2bfb9ac-09ad-4dfb-98f9-abfd96883da5"],

